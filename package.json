{
  "name": "@abadikan/ds",
  "version": "0.1.0",
  "description": "Abadikan Design System — Vue 3 component library",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./atoms": {
      "types": "./dist/atoms.d.ts",
      "import": "./dist/atoms.mjs",
      "require": "./dist/atoms.cjs"
    },
    "./molecules": {
      "types": "./dist/molecules.d.ts",
      "import": "./dist/molecules.mjs",
      "require": "./dist/molecules.cjs"
    },
    "./organisms": {
      "types": "./dist/organisms.d.ts",
      "import": "./dist/organisms.mjs",
      "require": "./dist/organisms.cjs"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.mjs",
      "require": "./dist/tokens.cjs"
    },
    "./styles": "./dist/style.css",
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": [
    "dist/style.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "size": "size-limit",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish",
    "test:e2e": "playwright test"
  },
  "size-limit": [
    {
      "path": "dist/atoms.mjs",
      "limit": "40 kB",
      "import": "*",
      "ignore": ["vue", "vue-i18n", "@remixicon/vue", "remixicon", "clsx", "@fontsource/inter", "@fontsource/jetbrains-mono"]
    },
    {
      "path": "dist/molecules.mjs",
      "limit": "120 kB",
      "import": "*",
      "ignore": ["vue", "vue-i18n", "@remixicon/vue", "remixicon", "clsx", "@fontsource/inter", "@fontsource/jetbrains-mono"]
    },
    {
      "path": "dist/organisms.mjs",
      "limit": "60 kB",
      "import": "*",
      "ignore": ["vue", "vue-i18n", "@remixicon/vue", "remixicon", "clsx", "@fontsource/inter", "@fontsource/jetbrains-mono"]
    },
    {
      "path": "dist/tokens.mjs",
      "limit": "5 kB",
      "import": "*",
      "ignore": ["vue", "vue-i18n"]
    },
    {
      "path": "dist/style.css",
      "limit": "80 kB"
    }
  ],
  "peerDependencies": {
    "vue": "^3.4.0",
    "vue-i18n": "^9.0.0"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@remixicon/vue": "^4.9.0",
    "@tailwindcss/vite": "^4.2.2",
    "clsx": "^2.1.1",
    "remixicon": "^4.9.1",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@chromatic-com/storybook": "^5.1.1",
    "@eslint/js": "^10.0.1",
    "@size-limit/preset-small-lib": "^12.0.1",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-onboarding": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/vue3-vite": "^10.3.3",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "chromatic": "^16.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.9",
    "mutationobserver-shim": "^0.3.7",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "size-limit": "^12.0.1",
    "storybook": "^10.3.3",
    "storybook-dark-mode": "^5.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2",
    "vue": "^3.4.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-i18n": "^9.0.0",
    "vue-tsc": "^3.2.5"
  }
}
